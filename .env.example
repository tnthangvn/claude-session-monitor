# Example environment file for local development of claude-session-monitor.
# Copy this file to `.env` and fill in your own values. Never commit `.env`.

# Telegram bot token issued by @BotFather (looks like 123456789:AA...).
TELEGRAM_BOT_TOKEN=

# Telegram group chat ID. For groups this is a NEGATIVE number, e.g. -1001234567890.
TELEGRAM_GROUP_ID=

# Session conflict window in seconds. If another machine started a session
# within this many seconds, it is treated as a concurrent-session conflict.
SESSION_TIMEOUT=300
