  "description": "Monitor Claude Code CLI sessions, detect concurrent sessions across machines, and notify a Telegram group via a PreToolUse hook.",
  "license": "MIT",
  "author": "Thang TN <tnthangvn@gmail.com>",
  "keywords": [
    "claude",
    "telegram",
    "session",
    "monitor",
    "cli",
    "hook"
  ],
  "bin": {
    "claude-session-monitor": "./bin/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
